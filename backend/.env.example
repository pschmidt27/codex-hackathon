PORT=3000
HOST=0.0.0.0

# Optional shared secret for protecting the API on a trusted network.
AUTH_SHARED_SECRET=
# Explicit demo-mode escape hatch for read-only knowledge APIs and MCP.
ALLOW_INSECURE_READ_ACCESS=false

VAULT_REPO_PATH=../vault-repo
GIT_REMOTE=origin
GIT_BRANCH=main

OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=

MAX_SUBMISSION_BYTES=65536
MAX_LLM_TOOL_ITERATIONS=24
