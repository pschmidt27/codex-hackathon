{
  "name": "personal-knowledge-base-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "pnpm format:check && pnpm typecheck && pnpm lint",
    "dev": "node --watch --env-file .env src/main.ts",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "lint": "eslint --max-warnings 0 .",
    "lint:file": "eslint --max-warnings 0",
    "lint:file:fix": "eslint --max-warnings 0 --fix",
    "lint:fix": "eslint --max-warnings 0 . --fix",
    "start": "node --env-file .env src/main.ts",
    "test": "node --test src/**/*.test.ts",
    "typecheck": "tsc --build tsconfig.json",
    "typecheck:watch": "pnpm run typecheck --watch"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.4",
    "@opentelemetry/api-logs": "^0.206.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-logs": "^0.206.0",
    "@opentelemetry/sdk-node": "^0.206.0",
    "hono": "^4.9.8",
    "openai": "^6.4.1",
    "zod": "^4.3.6",
    "zx": "^8.8.4"
  },
  "devDependencies": {
    "@types/node": "24",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^8.57.1",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^50.8.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-unicorn": "^55.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^2.5.22",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.15.0",
    "pnpm": "10.33.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.15.0",
      "onFail": "download"
    }
  }
}
